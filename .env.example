# Coach360 — environment variables
# Copy to .env (gitignored) and fill in real values for your environment.

# -----------------------------------------------------------------------------
# Supabase
# -----------------------------------------------------------------------------
#
# Local dev (recommended): start the Docker stack and grab values with
#   supabase start
#   supabase status -o env
#
# Cloud (staging / production): create a project at
# https://supabase.com/dashboard, then
#   supabase login
#   supabase link --project-ref <your-project-ref>
#   supabase db push          # applies migrations from supabase/migrations/
# Copy the Project URL and the public anon key from the dashboard into
# VITE_SUPABASE_URL / VITE_SUPABASE_ANON_KEY below.

VITE_SUPABASE_URL=http://127.0.0.1:54321
VITE_SUPABASE_ANON_KEY=

# -----------------------------------------------------------------------------
# Admin web app (apps/admin)
# -----------------------------------------------------------------------------
# Data adapter: supabase (default) | rest (future REST API)
VITE_API_ADAPTER=supabase
VITE_REST_API_BASE_URL=
VITE_SANITY_STUDIO_URL=https://studio.coach360.com
VITE_ADMIN_STAGING_URL=

# Server-only — never commit, never bundle into the Capacitor app.
# Used by edge functions, webhooks, and integration tests.
SUPABASE_SERVICE_ROLE_KEY=

# Optional defaults for `npm run seed:admin`
ADMIN_SEED_EMAIL=admin@coach360.local
ADMIN_SEED_PASSWORD=
ADMIN_SEED_DISPLAY_NAME=Local Admin
