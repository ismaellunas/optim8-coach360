{
  "appId": "com.coach360.app",
  "appName": "Coach360",
  "webDir": "apps/mobile/dist",
  "includePlugins": [
    "@capacitor/keyboard",
    "@capacitor/preferences",
    "@capacitor/status-bar"
  ],
  "plugins": {
    "Keyboard": {
      "resize": "body",
      "resizeOnFullScreen": true
    },
    "StatusBar": {
      "style": "dark",
      "backgroundColor": "#0C0C10"
    }
  },
  "ios": {
    "contentInset": "always",
    "limitsNavigationsToAppBoundDomains": true
  },
  "android": {
    "backgroundColor": "#0C0C10"
  }
}
